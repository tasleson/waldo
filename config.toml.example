# Waldo configuration

# Webhook URL to POST JSON events to
webhook_url = "https://hooks.slack.com/services/T00/B00/xxxx"

# Only send a "locked" notification if the screen stays locked for at
# least this many seconds. Prevents noise from brief screen locks.
min_lock_duration_secs = 300

# After sending any webhook, suppress further messages for this many
# seconds regardless of state changes.
cooldown_secs = 600

# Display name sent as the "USER" field in the webhook JSON payload
display_name = "Tony"

# Custom text for the STATUS_MSG field (defaults shown)
online_text = "online"
offline_text = "offline"
